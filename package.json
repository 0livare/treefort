{
  "name": "treefort",
  "version": "0.0.1",
  "description": "git worktrees without the work",
  "author": "Zach Olivare <https://github.com/0livare>",
  "license": "ISC",
  "repository": "https://github.com/0livare/treefort",
  "bin": {
    "wt": "src/main.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "wt": "bun src/main.ts",
    "link": "bun link",
    "types": "tsc",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "pr": "bun run types && bun run check"
  },
  "dependencies": {
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "^1.3.6",
    "@types/node": "^24.12.3",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "git",
    "worktree",
    "cli",
    "helper"
  ],
  "packageManager": "bun@1.3.13"
}
